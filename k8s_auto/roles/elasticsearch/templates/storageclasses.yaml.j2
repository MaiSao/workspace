apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  annotations:
    defaultVolumeType: hostPath
  name: {{ elasticsearch_storage_classes.data.name }}
parameters:
  nodePath: {{ elasticsearch_storage_classes.data.node_path }}
provisioner: {{ local_path_provisioner_name }}
reclaimPolicy: {{ elasticsearch_storage_classes.data.reclaim_policy }}
volumeBindingMode: {{ elasticsearch_storage_classes.data.volume_binding_mode }}
allowVolumeExpansion: {{ elasticsearch_storage_classes.data.allow_volume_expansion | bool | lower }}
---
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  annotations:
    defaultVolumeType: hostPath
  name: {{ elasticsearch_storage_classes.log.name }}
parameters:
  nodePath: {{ elasticsearch_storage_classes.log.node_path }}
provisioner: {{ local_path_provisioner_name }}
reclaimPolicy: {{ elasticsearch_storage_classes.log.reclaim_policy }}
volumeBindingMode: {{ elasticsearch_storage_classes.log.volume_binding_mode }}
allowVolumeExpansion: {{ elasticsearch_storage_classes.log.allow_volume_expansion | bool | lower }}
