global
    log         127.0.0.1 local2
    chroot      /var/lib/haproxy
    pidfile     /var/run/haproxy.pid
    maxconn     4000
    user        haproxy
    group       haproxy
    daemon
    stats socket /var/lib/haproxy/stats

defaults
    log                     global
    mode                    tcp
    option                  tcplog
    option                  dontlognull
    retries                 3
    timeout connect         10s
    timeout client          1m
    timeout server          1m
    timeout check           10s
    maxconn                 3000

frontend apiserver
    bind *:{{ ha_apiserver_port }}
    mode tcp
    option tcplog
    default_backend apiserver

backend apiserver
    mode tcp
    option tcp-check
    balance roundrobin
{% for host in groups['master'] %}
    server {{ hostvars[host]['ansible_hostname'] | default(host) }} {{ hostvars[host]['k8s_ip'] | default(host) }}:{{ localAPIEndpointPort }} check fall 2 rise 3 inter 2s
{% endfor %}
