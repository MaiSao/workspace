! /etc/keepalived/keepalived.conf
! Configuration File for keepalived

global_defs {
    enable_script_security
    router_id LVS_DEVEL
}

vrrp_script check_apiserver {
    script "/etc/keepalived/check_apiserver.sh"
    interval 3
    weight -2
    fall 10
    rise 2
}

vrrp_instance VI_1 {
{% set keepalived_node_index = groups['k8s-master'].index(inventory_hostname) %}
    state {{ 'MASTER' if keepalived_node_index == 0 else 'BACKUP' }}
    interface {{ interface_k8s }}
    virtual_router_id {{ __keepalived_vrrp_router_id }}
    priority {{ (keepalived_priority_base | int) - keepalived_node_index }}
    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }
    virtual_ipaddress {
        {{ k8s_master_ip }}/{{ keepalived_vip_prefix | default(24) }}
    }
    track_script {
        check_apiserver
    }
}
