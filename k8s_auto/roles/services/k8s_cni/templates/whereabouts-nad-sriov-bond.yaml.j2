{% for network in sriov_pf_mappings %}
apiVersion: "k8s.cni.cncf.io/v1"
kind: NetworkAttachmentDefinition
metadata:
  name: {{ network.nad }}
  annotations:
    k8s.v1.cni.cncf.io/resourceName: {{ sriov_resource_prefix }}/{{ network.resource }}
spec:
  config: |-
    {
      "cniVersion": "0.3.1",
      "name": "{{ network.nad }}",
      "type": "sriov",
      "vlan": {{ sriov_bond_groups[network.group].vlan }}
    }
---
{% endfor %}
{% for network in sriov_bond_networks %}
{% set group = sriov_bond_groups[network.group] %}
apiVersion: "k8s.cni.cncf.io/v1"
kind: NetworkAttachmentDefinition
metadata:
  name: {{ network.name }}
spec:
  config: |-
    {
      "cniVersion": "0.3.1",
      "name": "{{ network.name }}",
      "type": "bond",
      "ifname": "{{ network.ifname | default(network.name) }}",
      "vlan": {{ group.vlan }},
      "mode": "{{ network.mode | default(sriov_bond_defaults.mode) }}",
      "failOverMac": {{ network.failOverMac | default(sriov_bond_defaults.failOverMac) }},
      "linksInContainer": {{ network.linksInContainer | default(sriov_bond_defaults.linksInContainer) | to_json }},
      "miimon": "{{ network.miimon | default(sriov_bond_defaults.miimon) }}",
      "links": [
{% for link in group.links %}
        {"name": "{{ link }}"}{% if not loop.last %},{% endif %}
{% endfor %}
      ],
      "ipam": {
        "type": "whereabouts",
        "datastore": "kubernetes",
        "kubernetes": { "kubeconfig": "/etc/cni/net.d/whereabouts.d/whereabouts.kubeconfig" },
        "log_file": "/var/log/net-attach-def-{{ network.name }}.log",
        "log_level": "debug",
        "range": "{{ network.range | default(group.range) }}",
{% if network.range_start is defined %}
        "range_start": "{{ network.range_start }}",
{% endif %}
{% if network.range_end is defined %}
        "range_end": "{{ network.range_end }}",
{% endif %}
{% if network.range_start is not defined and network.exclude is not defined %}
        "exclude": {{ group.exclude | to_json }},
{% elif network.exclude is defined %}
        "exclude": {{ network.exclude | to_json }},
{% endif %}
        "routes": [{
          "dst": "0.0.0.0/0"
        }],
        "gateway": "{{ network.gateway | default(group.gateway) }}"
      }
    }
{% if not loop.last %}
---
{% endif %}
{% endfor %}
