#!/bin/env bash
set -Eeuo pipefail
trap 'echo "[ERROR] k8s-ha-bootstrap.sh failed at line ${LINENO}: ${BASH_COMMAND}" >&2' ERR

dnf install -y kubectl haproxy keepalived k9s
setsebool -P haproxy_connect_any=1 || true
semanage port -a -t http_port_t -p tcp 8443 || true
cat > /etc/keepalived/keepalived.conf <<'EOF'
! /etc/keepalived/keepalived.conf
! Configuration File for keepalived

global_defs {
    enable_script_security
    router_id LVS_DEVEL
}

vrrp_script check_apiserver {
    script "/etc/keepalived/check_apiserver.sh"
    interval 3
    weight -2
    fall 10
    rise 2
}

vrrp_instance VI_1 {
    state MASTER
    interface {{ interface_k8s }}
    virtual_router_id {{ keepalived_vrrp_router_id }}
    priority 25{{ priority }}
    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }
    virtual_ipaddress {
        {{ k8s_master_ip }}
    }
    track_script {
        check_apiserver
    }
}
EOF

cat > /etc/haproxy/haproxy.cfg <<'EOF'
global
    log         127.0.0.1 local2
    chroot      /var/lib/haproxy
    pidfile     /var/run/haproxy.pid
    maxconn     4000
    user        haproxy
    group       haproxy
    daemon
    stats socket /var/lib/haproxy/stats
defaults
    mode                    http
    log                     global
    option                  httplog
    option                  dontlognull
    option http-server-close
    option forwardfor       except 127.0.0.0/8
    option                  redispatch
    retries                 3
    timeout http-request    10s
    timeout queue           1m
    timeout connect         10s
    timeout client          1m
    timeout server          1m
    timeout http-keep-alive 10s
    timeout check           10s
    maxconn                 3000
EOF

cat > /etc/haproxy/conf.d/kubernetes.cfg <<'EOF'
frontend apiserver
    bind *:{{ ha_apiserver_port }}
    mode tcp
    option tcplog
    default_backend apiserver
backend apiserver
    option httpchk GET /healthz
    timeout check 2s
    http-check expect status 200
    mode tcp
    option ssl-hello-chk
    balance     roundrobin
{% for i in groups['master'] %}
    server {{ hostvars[i]['ansible_hostname'] }} {{i}}:{{ localAPIEndpointPort }}  check fall 2 rise 3 inter 2s
{% endfor %}
EOF

cat > /etc/keepalived/check_apiserver.sh <<'EOF'
#!/bin/bash

APISERVER_VIP={{ k8s_master_ip }}
APISERVER_DEST_PORT={{ ha_apiserver_port }}

errorExit() {
    echo "* * * $*" 1>&2
        exit 1
}

curl --silent --max-time 2 \
         --insecure https://localhost:${APISERVER_DEST_PORT}/ \
         -o /dev/null || errorExit "Error GET https://localhost:${APISERVER_DEST_PORT}/"

if ip addr | grep -q ${APISERVER_VIP}; then
    curl --silent --max-time 2 \
        --insecure https://${APISERVER_VIP}:${APISERVER_DEST_PORT}/ \
        -o /dev/null || errorExit "Error GET https://${APISERVER_VIP}:${APISERVER_DEST_PORT}/"
fi
EOF
chmod +x /etc/keepalived/check_apiserver.sh

systemctl enable --now keepalived haproxy
systemctl restart keepalived
systemctl restart haproxy
echo 'KubeMaster' > /etc/kube-master-metadata
