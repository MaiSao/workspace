cd /tmp/harbor
### Create ca.key
openssl genrsa -out ca.key 4096

### create CA
openssl req -x509 -new -nodes -sha512 -days {{ cert_expired_days }} \
 -subj "/C=CN/ST=Hanoi/L=Hanoi/O=VHT/OU=Personal/CN={{ harbor_domain }}" \
 -key ca.key \
 -out ca.crt

### gen server ca
openssl genrsa -out {{ harbor_domain }}.key 4096

### 

openssl req -sha512 -new \
-subj "/C=CN/ST=Hanoi/L=Hanoi/O=VHT/OU=Personal/CN={{ harbor_domain }}" \
-key {{ harbor_domain }}.key \
-out {{ harbor_domain }}.csr


### create v3.ext
cat > v3.ext <<-EOF
authorityKeyIdentifier=keyid,issuer
basicConstraints=CA:FALSE
keyUsage = digitalSignature, nonRepudiation, keyEncipherment, dataEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names
[alt_names]
IP.1 = {{ harbor_haip }}
{% for item in groups['HARBOR'] %}
IP.{{ loop.index + 1 }} = {{ hostvars[item].ansible_host }}
{% endfor %}
DNS.1={{ harbor_domain }}
DNS.2=docker-registry
DNS.3=harbor-registry
EOF


openssl x509 -req -sha512 -days {{ cert_expired_days }} \
-extfile v3.ext \
-CA ca.crt -CAkey ca.key -CAcreateserial \
-in {{ harbor_domain }}.csr \
-out {{ harbor_domain }}.crt


openssl x509 -inform PEM -in {{ harbor_domain }}.crt -out {{ harbor_domain }}.cert
cat {{ harbor_domain }}.crt {{ harbor_domain }}.key > {{ harbor_domain }}.pem
