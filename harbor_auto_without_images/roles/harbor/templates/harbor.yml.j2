hostname: {{ ansible_host }}

http:
  port: {{ http_port }}

https:
  port: {{ https_port }}
  certificate: {{ https_cert_dir }}/{{ harbor_domain }}.crt
  private_key: {{ https_cert_dir }}/{{ harbor_domain }}.key

harbor_admin_password: {{ harbor_password }}

database:
  password: {{ database_password }}
  max_idle_conns: 100
  max_open_conns: 900

data_volume: {{ harbor_data_volume }}

trivy:
  ignore_unfixed: false
  skip_update: false
  offline_scan: false
  insecure: false

jobservice:
  max_job_workers: 10
  max_job_duration_hours: 24
  job_loggers:
    - STD_OUTPUT
    - FILE
  logger_sweeper_duration: 1

notification:
  webhook_job_max_retry: 10
  webhook_job_http_client_timeout: 3

chart:
  absolute_url: disabled

log:
  level: info
  local:
    rotate_count: 50
    rotate_size: 200M
    location: {{ harbor_data_volume }}/log
_version: {{ harbor_version }}
proxy:
  http_proxy:
  https_proxy:
  no_proxy:
  components:
    - core
    - jobservice
    - trivy

metric:
  enabled: true
  port: 8090
  path: /metrics
